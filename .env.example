# database
# local dev assumes the docker-compose postgres service
DATABASE_URL="postgresql://mira:mira@localhost:5432/mira?schema=public"

# app
NEXT_PUBLIC_APP_NAME="Mira Health Intelligence"
NEXT_PUBLIC_APP_ENV="development"

# ai providers — wired in phase 2
# choose one of: mock | openai | groq
AI_PROVIDER="mock"
OPENAI_API_KEY=""
GROQ_API_KEY=""

# observability — optional
LOG_LEVEL="info"
