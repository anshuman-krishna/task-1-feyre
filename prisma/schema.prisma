// mira health intelligence — schema
// designed for future multi-tenant + ai orchestration without rework

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  low
  moderate
  elevated
  critical
}

enum PredictionProvider {
  mock
  internal
  openai
  groq
  huggingface
}

enum AuditAction {
  create
  update
  archive
  restore
  predict
  predict_fail
  note_add
  note_remove
  export
  view
  assign
  status_change
  sign_in
  sign_out
}

enum Role {
  admin
  clinician
  analyst
}

enum WorkflowStatus {
  new_patient        @map("new")
  monitoring
  follow_up_needed
  stable
  urgent_review
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(clinician)
  avatarHue Int      @default(180)
  archivedAt DateTime?

  assignedPatients Patient[]  @relation("AssignedClinician")
  auditLogs        AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Patient {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  dob       DateTime @db.Date
  sex       String?

  // diagnostic inputs
  glucose             Float?
  haemoglobin         Float?
  cholesterol         Float?
  systolic            Int?
  diastolic           Int?
  bmi                 Float?

  // mirrored snapshot of the latest prediction (cheap list reads)
  aiPrediction         String?
  riskLevel            RiskLevel?
  predictionConfidence Float?
  lastPredictedAt      DateTime?

  // workflow
  status        WorkflowStatus @default(new_patient)
  assignedToId  String?
  assignedTo    User?          @relation("AssignedClinician", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpAt    DateTime?
  reviewedAt    DateTime?

  archivedAt DateTime?

  predictions PredictionLog[]
  notes       Note[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([riskLevel, archivedAt])
  @@index([status, archivedAt])
  @@index([assignedToId])
  @@index([followUpAt])
  @@index([createdAt])
  @@index([archivedAt])
  @@map("patients")
}

model PredictionLog {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  provider        PredictionProvider
  model           String?
  riskLevel       RiskLevel
  condition       String
  confidence      Float
  summary         String
  recommendations Json
  observations    Json
  contributions   Json // [{ label, weight: 0..1, direction: 'up'|'neutral' }]

  inputSnapshot   Json
  requestPayload  Json
  responsePayload Json
  latencyMs       Int
  error           String?

  createdAt DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([provider])
  @@map("prediction_logs")
}

model Note {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  body      String
  author    String  @default("system")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@map("notes")
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String
  entityId    String
  performedBy String?
  metadata    Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([patientId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
