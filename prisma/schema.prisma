// mira health intelligence — schema
// production-scalable foundation: tenant-ready, queue-backed predictions,
// stored notifications, audit fidelity

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  low
  moderate
  elevated
  critical
}

enum PredictionProvider {
  mock
  internal
  openai
  groq
  huggingface
}

enum AuditAction {
  create
  update
  archive
  restore
  predict
  predict_fail
  note_add
  note_remove
  export
  view
  assign
  status_change
  sign_in
  sign_out
  bulk_archive
  bulk_status
}

enum Role {
  admin
  clinician
  analyst
}

enum WorkflowStatus {
  new_patient        @map("new")
  monitoring
  follow_up_needed
  stable
  urgent_review
}

enum PredictionJobStatus {
  queued
  processing
  completed
  failed
  dead
}

enum NotificationType {
  prediction_completed
  prediction_failed
  follow_up_due
  patient_critical
  system
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  patients      Patient[]
  notifications Notification[]

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  email     String   @unique
  role      Role     @default(clinician)
  avatarHue Int      @default(180)
  archivedAt DateTime?

  assignedPatients Patient[]      @relation("AssignedClinician")
  auditLogs        AuditLog[]
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("users")
}

model Patient {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  fullName  String
  email     String
  dob       DateTime @db.Date
  sex       String?

  glucose             Float?
  haemoglobin         Float?
  cholesterol         Float?
  systolic            Int?
  diastolic           Int?
  bmi                 Float?

  aiPrediction         String?
  riskLevel            RiskLevel?
  predictionConfidence Float?
  lastPredictedAt      DateTime?

  status        WorkflowStatus @default(new_patient)
  assignedToId  String?
  assignedTo    User?          @relation("AssignedClinician", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpAt    DateTime?
  reviewedAt    DateTime?

  archivedAt DateTime?

  predictions    PredictionLog[]
  predictionJobs PredictionJob[]
  notes          Note[]
  auditLogs      AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId, archivedAt])
  @@index([riskLevel, archivedAt])
  @@index([status, archivedAt])
  @@index([assignedToId])
  @@index([followUpAt])
  @@index([createdAt])
  @@map("patients")
}

model PredictionLog {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  provider        PredictionProvider
  model           String?
  riskLevel       RiskLevel
  condition       String
  confidence      Float
  summary         String
  recommendations Json
  observations    Json
  contributions   Json

  inputSnapshot   Json
  requestPayload  Json
  responsePayload Json
  latencyMs       Int
  error           String?

  createdAt DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([provider])
  @@map("prediction_logs")
}

model PredictionJob {
  id           String              @id @default(cuid())
  patientId    String
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status       PredictionJobStatus @default(queued)
  attempts     Int                 @default(0)
  maxAttempts  Int                 @default(3)
  provider     String?
  scheduledFor DateTime            @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  resultId     String?
  requestedBy  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledFor])
  @@index([patientId, createdAt])
  @@map("prediction_jobs")
}

model Note {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  body      String
  author    String  @default("system")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@map("notes")
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entityType  String
  entityId    String
  performedBy String?
  metadata    Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([patientId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  body    String?
  link    String?
  payload Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([organizationId, createdAt])
  @@map("notifications")
}
